    {
      "type": "dialogue",
      "title_zh": "看醫生",
      "lines": [
        {
          "speaker": "醫生",
          "de": "Hallo. Was kann ich für Sie tun?",
          "zh": "您好，需要什麼協助？"
        },
        {
          "speaker": "病人",
          "de": "Mir geht es heute nicht so gut. Ich glaube, ich bin krank.",
          "zh": "我今天不舒服，我覺得我生病了。"
        },
        {
          "speaker": "醫生",
          "de": "Aha. Haben Sie Fieber?",
          "zh": "嗯。有發燒嗎？"
        },
        {
          "speaker": "病人",
          "de": "Ja, aber nur ein bisschen. Nicht sehr hoch... 38,2 °.",
          "zh": "有，但不高，38.2 度。"
        },
        {
          "speaker": "醫生",
          "de": "Und haben Sie auch Husten?",
          "zh": "也有咳嗽嗎？"
        },
        {
          "speaker": "病人",
          "de": "Nein, aber mein Hals tut weh und meine Nase läuft.",
          "zh": "沒有，但喉嚨痛、流鼻水。"
        },
        {
          "speaker": "醫生",
          "de": "Keine Sorge! Ich glaube, das ist nur eine Erkältung. Bleiben Sie 2 Tage im Bett.",
          "zh": "別擔心，只是普通感冒。請臥床休息兩天。"
        },
        {
          "speaker": "病人",
          "de": "Was kann ich gegen die Erkältung tun? Soll ich auch Schmerztabletten nehmen?",
          "zh": "感冒要怎麼處理？要吃止痛藥嗎？"
        },
        {
          "speaker": "醫生",
          "de": "Ja, gegen das Fieber können Sie Tabletten nehmen.",
          "zh": "要，發燒可以吃藥。"
        },
        {
          "speaker": "病人",
          "de": "Brauche ich ein Rezept für die Tabletten?",
          "zh": "需要處方箋嗎？"
        },
        {
          "speaker": "醫生",
          "de": "Nein nein, die bekommen Sie in der Apotheke ohne Rezept.",
          "zh": "不用，到藥局直接買就好。"
        }
      ]
    },
