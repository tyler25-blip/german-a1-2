{
  "id": 6,
  "title_de": "Body & health",
  "title_zh": "身體與健康",
  "topic_zh": "形容身體狀況、給敬語建議、看醫生",
  "grammar_focus": [
    "formal imperative (Sie)",
    "modal verb sollen",
    "body parts"
  ],
  "sections": [
    {
      "type": "intro",
      "title_zh": "本章你會學到",
      "zh": "全身上下身體部位的德文，看醫生時怎麼描述身體不舒服（頭痛、感冒、發燒…），以及兩個重要文法：① Sie 命令式（醫生對病人這種敬語下達指令）；② sollen（情態動詞『應該 / 別人交代要…』）。"
    },
    {
      "type": "grammar",
      "title_de": "Imperativ mit Sie (formell)",
      "title_zh": "敬語命令式：Sie",
      "explanation_zh": "對長輩、客戶、醫生病人之間用 Sie。命令句變法很簡單：把動詞放在第一位，主詞 Sie 放在動詞後。動詞變位完全照原本 Sie 的形式（= 動詞原型）。",
      "tables": [
        {
          "title": "命令式形式",
          "headers": [
            "動詞",
            "Sie 命令式",
            "中文"
          ],
          "rows": [
            [
              "nehmen",
              "Nehmen Sie!",
              "請拿 / 服用！"
            ],
            [
              "trinken",
              "Trinken Sie!",
              "請喝！"
            ],
            [
              "schlafen",
              "Schlafen Sie!",
              "請睡！"
            ],
            [
              "bleiben",
              "Bleiben Sie!",
              "請留下！"
            ]
          ]
        }
      ],
      "examples": [
        {
          "de": "Nehmen Sie dreimal pro Tag die Tabletten.",
          "zh": "請每天服用三次藥錠。"
        },
        {
          "de": "Trinken Sie mindestens 2 Liter Wasser.",
          "zh": "請每天至少喝 2 公升的水。"
        },
        {
          "de": "Schlafen Sie viel.",
          "zh": "請多睡。"
        }
      ],
      "tips_zh": "想讓命令聽起來不那麼硬，加 doch（『不如…』）：『Trinken Sie doch einen Hustentee.』 = 『不然喝杯止咳茶吧。』"
    },
    {
      "type": "grammar",
      "title_de": "Modalverb: sollen",
      "title_zh": "情態動詞：sollen（被交代）",
      "explanation_zh": "sollen 表示『別人要我這樣做』— 通常是醫生、老師、爸媽『交代下來』的指令。注意：sollen ≠ 英文的 should（建議）。如果你要說『建議你應該…』那是 sollten。",
      "tables": [
        {
          "title": "sollen 變位",
          "headers": [
            "人稱",
            "sollen"
          ],
          "rows": [
            [
              "ich",
              "soll"
            ],
            [
              "du",
              "sollst"
            ],
            [
              "er / sie / es",
              "soll"
            ],
            [
              "wir",
              "sollen"
            ],
            [
              "ihr",
              "sollt"
            ],
            [
              "sie / Sie",
              "sollen"
            ]
          ]
        }
      ],
      "examples": [
        {
          "de": "Die Ärztin hat gesagt, ich soll diese Tabletten nehmen.",
          "zh": "醫生說我要吃這些藥。"
        },
        {
          "de": "Du sollst auch viel Wasser trinken.",
          "zh": "你也應該多喝水（醫生說的）。"
        },
        {
          "de": "Ich soll im Bett bleiben.",
          "zh": "我得躺床上。"
        }
      ],
      "tips_zh": "sollen 跟其他情態動詞一樣：sollen 變位放第二位，主要動詞用原型放句尾。"
    },
