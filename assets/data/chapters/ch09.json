{
  "id": 9,
  "title_de": "Rules",
  "title_zh": "規則",
  "topic_zh": "談規則、必須與允許、用 weil 解釋原因",
  "grammar_focus": [
    "modal verbs müssen / dürfen",
    "subordinate clauses with weil"
  ],
  "sections": [
    {
      "type": "intro",
      "title_zh": "本章你會學到",
      "zh": "兩個跟『規則』有關的情態動詞：müssen（必須）和 dürfen（被允許）。再學德文最重要的子句連接詞 weil（因為），讓你能解釋『為什麼』 — 這是 A1 進入 A2 的分水嶺，因為 Nebensatz（子句）會把動詞丟到句尾，動詞位置改變了！"
    },
    {
      "type": "grammar",
      "title_de": "Modalverb: dürfen",
      "title_zh": "情態動詞：dürfen（被允許）",
      "explanation_zh": "dürfen 表示『被允許做』。否定句 nicht dürfen ＝『不被允許』≈ 英文 mustn't。",
      "tables": [
        {
          "headers": [
            "人稱",
            "dürfen"
          ],
          "rows": [
            [
              "ich",
              "darf"
            ],
            [
              "du",
              "darfst"
            ],
            [
              "er / sie / es",
              "darf"
            ],
            [
              "wir",
              "dürfen"
            ],
            [
              "ihr",
              "dürft"
            ],
            [
              "sie / Sie",
              "dürfen"
            ]
          ]
        }
      ],
      "examples": [
        {
          "de": "Darf ich hier etwas essen?",
          "zh": "我可以在這吃東西嗎？"
        },
        {
          "de": "Nein, hier dürfen Sie nicht essen.",
          "zh": "不行，這裡禁止飲食。"
        },
        {
          "de": "Dürfen wir heute PS5 spielen? — Ja, ihr dürft 2 Stunden spielen.",
          "zh": "今天可以玩 PS5 嗎？— 可以玩兩小時。"
        }
      ]
    },
    {
      "type": "grammar",
      "title_de": "Modalverb: müssen",
      "title_zh": "情態動詞：müssen（必須）",
      "explanation_zh": "müssen ＝『必須 / 不得不』。注意一個常見的『假朋友』陷阱：英文 must not ≠ 德文 muss nicht！否定的 müssen 是『不必』，禁止才是 darf nicht。",
      "tables": [
        {
          "headers": [
            "人稱",
            "müssen"
          ],
          "rows": [
            [
              "ich",
              "muss"
            ],
            [
              "du",
              "musst"
            ],
            [
              "er / sie / es",
              "muss"
            ],
            [
              "wir",
              "müssen"
            ],
            [
              "ihr",
              "müsst"
            ],
            [
              "sie / Sie",
              "müssen"
            ]
          ]
        }
      ],
      "examples": [
        {
          "de": "Ich muss um 7:30 Uhr aufstehen.",
          "zh": "我必須 7:30 起床。"
        },
        {
          "de": "Musst du oft im Haushalt helfen?",
          "zh": "你常需要做家事嗎？"
        },
        {
          "de": "Du musst nicht kommen.",
          "zh": "你『不必』來。（≠ 你不能來！）"
        },
        {
          "de": "Du darfst nicht kommen.",
          "zh": "你『不能』來。（被禁止）"
        }
      ],
      "tips_zh": "規則告示牌常見字：verboten（禁止）、erlaubt（允許）。例如『Radfahren verboten』＝『禁止騎車』。"
    },
    {
      "type": "grammar",
      "title_de": "Nebensatz mit „weil\"",
      "title_zh": "子句連接詞 weil（因為）",
      "explanation_zh": "weil 是德文最常用的『因為』。重點：weil 之後是『子句（Nebensatz）』，**動詞會被踢到子句最後**！這跟主句『動詞放第二位』完全相反，是 A1 學員最常出錯的地方。",
      "tables": [
        {
          "title": "主句 + weil 子句",
          "headers": [
            "主句（結果）",
            ",",
            "weil + 主詞 + …",
            "動詞放最後"
          ],
          "rows": [
            [
              "Sie hat Kopfschmerzen",
              ",",
              "weil Deutsch so kompliziert",
              "ist."
            ],
            [
              "Er ist zu Hause",
              ",",
              "weil er Hausaufgaben machen",
              "muss."
            ],
            [
              "Janosh ist reich",
              ",",
              "weil er im Lotto gewonnen",
              "hat."
            ],
            [
              "Karina ist sauer",
              ",",
              "weil ihr Sohn sein Zimmer nicht",
              "aufräumt."
            ]
          ]
        }
      ],
      "examples": [
        {
          "de": "Er hat Kopfschmerzen, weil Deutsch so kompliziert ist.",
          "zh": "他頭痛，因為德文太複雜。"
        },
        {
          "de": "Sie ist sehr nervös, weil sie morgen einen Test schreibt.",
          "zh": "她很緊張，因為明天有考試。"
        }
      ],
      "tips_zh": "可分動詞在子句裡會『合體』：er räumt auf → weil er aufräumt。情態動詞句：…machen muss（變位的 muss 在最後，原型 machen 在它前面）。"
    },
