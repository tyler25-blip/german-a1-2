      ],
      "examples": [
        {
          "de": "Wo ist das Buch? — Das Buch ist unter dem Tisch.",
          "zh": "書在哪？— 書在桌子下面。"
        },
        {
          "de": "Wo ist das Kissen? — Das Kissen ist auf dem Sofa.",
          "zh": "枕頭在哪？— 枕頭在沙發上。"
