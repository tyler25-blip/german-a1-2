{
  "id": 10,
  "title_de": "Clothes",
  "title_zh": "服裝",
  "topic_zh": "比較大小、好壞、價格；表達『願望／如果…就好了』",
  "grammar_focus": [
    "comparative & superlative",
    "Konjunktiv II with würden"
  ],
  "sections": [
    {
      "type": "intro",
      "title_zh": "本章你會學到",
      "zh": "形容詞的『比較級／最高級』 — 怎麼說『更便宜、最便宜』、『更長、最長』；以及德文的虛擬式 würden（『會想…』、『若…就好了』），用來表達夢想 / 假設。最後再認一輪服裝單字。"
    },
    {
      "type": "grammar",
      "title_de": "Komparativ & Superlativ",
      "title_zh": "比較級與最高級",
      "explanation_zh": "三段：形容詞原型 → 比較級（加 -er）→ 最高級（am ___ -sten）。比較兩物用 als（比…）；想說『一樣…』用 (genau)so + 形容詞 + wie。",
      "tables": [
        {
          "title": "規則變化",
          "headers": [
            "原型",
            "Komparativ (-er)",
            "Superlativ (am … -sten)"
          ],
          "rows": [
            [
              "billig 便宜",
              "billiger",
              "am billigsten"
            ],
            [
              "schön 漂亮",
              "schöner",
              "am schönsten"
            ],
            [
              "klein 小",
              "kleiner",
              "am kleinsten"
            ]
          ]
        },
        {
          "title": "重要變化規則",
          "headers": [
            "規則",
            "原型 → 比較 → 最高"
          ],
          "rows": [
            [
              "單音節 a / o / u → ä / ö / ü",
              "alt → älter → am ältesten"
            ],
            [
              "",
              "lang → länger → am längsten"
            ],
            [
              "",
              "groß → größer → am größten"
            ],
            [
              "",
              "jung → jünger → am jüngsten"
            ],
            [
              "以 d / s / t / z / ß 結尾 → 最高加 -esten",
              "leicht → leichter → am leichtesten"
            ],
            [
              "",
              "alt → älter → am ältesten"
            ]
          ]
        },
        {
          "title": "重要不規則（必背 4 個）",
          "headers": [
            "原型",
            "Komparativ",
            "Superlativ"
          ],
          "rows": [
            [
              "gern 喜歡",
              "lieber",
              "am liebsten"
            ],
            [
              "gut 好",
              "besser",
              "am besten"
            ],
            [
              "viel 多",
              "mehr",
              "am meisten"
            ],
            [
              "hoch 高",
              "höher",
              "am höchsten"
            ]
          ]
        }
      ],
      "examples": [
        {
          "de": "Der Mantel ist billig. Die Jacke ist billiger als der Mantel. Der Pullover ist am billigsten.",
          "zh": "外套便宜，夾克比外套便宜，毛衣最便宜。"
        },
        {
          "de": "Tim trägt lieber Jogginghosen als Jeans.",
          "zh": "Tim 比較喜歡穿運動褲而非牛仔褲。"
        },
        {
          "de": "Tina findet Kapuzenpullis am besten.",
          "zh": "Tina 覺得帽 T 最棒。"
        }
      ]
    },
    {
      "type": "grammar",
      "title_de": "Vergleiche: als & so…wie",
      "title_zh": "als（比）與 so…wie（一樣）",
      "explanation_zh": "比較句型：① Komparativ + als（…比…）；② (genau)so + 形容詞 + wie（一樣…）。",
      "examples": [
        {
          "de": "Tims Flip-Flops sind größer als Katis.",
          "zh": "Tim 的夾腳拖比 Kati 的大。"
        },
        {
          "de": "Kati mag Hosen lieber als Röcke.",
          "zh": "Kati 喜歡褲子甚於裙子。"
        },
        {
          "de": "Der Schal ist genauso teuer wie die Handschuhe.",
          "zh": "圍巾跟手套一樣貴。"
        },
        {
          "de": "Max kauft T-Shirts so oft wie Yvonne.",
          "zh": "Max 買 T 恤跟 Yvonne 一樣常。"
        }
      ],
      "tips_zh": "口語常聽到 als 跟 wie 混用，但**正式**德文：『比較』用 als，『相同』用 wie。考試時別寫 mehr wie ich！正解是 mehr als ich。"
    },
    {
      "type": "grammar",
      "title_de": "Konjunktiv II: würden",
      "title_zh": "虛擬式：würden（會想 / 假設）",
      "explanation_zh": "würden 是 werden 的虛擬式，用來表達『願望』、『假設』。最簡單用法是『würden + gern + 動詞原型（放最後）』 = 『會想做…』。",
      "tables": [
        {
          "title": "würden 變位",
          "headers": [
            "人稱",
            "würden"
          ],
          "rows": [
            [
              "ich",
              "würde"
            ],
            [
              "du",
              "würdest"
            ],
            [
              "er / sie / es",
              "würde"
            ],
            [
              "wir",
              "würden"
            ],
            [
              "ihr",
              "würdet"
            ],
            [
              "sie / Sie",
              "würden"
            ]
          ]
        },
        {
          "title": "三種句型",
          "headers": [
            "結構",
            "範例"
          ],
          "rows": [
            [
              "würden + 動詞",
              "Sie würde als Ärztin arbeiten."
            ],
            [
              "würden + gern + 動詞",
              "Wir würden gern Urlaub machen."
            ],
            [
              "würden + 形容詞 (跟 sein/werden)",
              "Ich würde gern reich werden."
            ]
          ]
        }
      ],
      "examples": [
        {
          "de": "Wo würdest du gern leben? — Ich würde gern in Deutschland leben.",
          "zh": "你會想住哪？— 我會想住德國。"
        },
        {
          "de": "Würdet ihr gern ein Haus am Meer kaufen? — Ja, klar.",
          "zh": "你們會想在海邊買房嗎？— 當然。"
        },
        {
          "de": "Was würdest du heute Abend gern machen? — Ich würde gern fernsehen und Chips essen.",
          "zh": "今晚想幹嘛？— 想看電視吃洋芋片。"
        }
      ]
    },
