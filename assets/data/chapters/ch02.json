    {
      "type": "dialogue",
      "title_zh": "看公寓：Nina 的家",
      "lines": [
        {
          "speaker": "A",
          "de": "Hast du Ninas Schlafzimmer schon gesehen?",
          "zh": "你看過 Nina 的臥室了嗎？"
        },
        {
          "speaker": "B",
          "de": "Ja, es ist sehr groß.",
          "zh": "看了，超大的。"
        },
        {
          "speaker": "A",
          "de": "Gibt es auch ein Arbeitszimmer?",
          "zh": "她家有書房嗎？"
        },
        {
          "speaker": "B",
          "de": "Ja klar... im 1. Stock. Dort ist auch Peters Arbeitszimmer.",
          "zh": "當然有，在二樓。Peter 的書房也在那。"
        },
        {
          "speaker": "A",
          "de": "Ah ja, stimmt. Peter braucht den Computer für seine Arbeit.",
          "zh": "對，Peter 工作需要用電腦。"
        },
        {
          "speaker": "B",
          "de": "Und seine Kamera... Er ist Fotograf.",
          "zh": "還有他的相機，他是攝影師。"
        },
        {
          "speaker": "A",
          "de": "Nina liest abends sehr gern. Sind ihre Bücher im Arbeitszimmer?",
          "zh": "Nina 晚上很愛閱讀。她的書放書房嗎？"
        },
        {
          "speaker": "B",
          "de": "Nein, ihre Bücher sind in einem Regal im Wohnzimmer.",
          "zh": "不，她的書在客廳的書架上。"
        }
      ]
    },
