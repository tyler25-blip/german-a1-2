    {
      "type": "exercise",
      "title_zh": "練習 1：Mario 和 Iris — sein 還是 ihr？",
      "instruction_zh": "看主詞是男是女，並注意句中該空格是 Nominativ（主格）還是 Akkusativ（受格），填入 sein-/ihr- 的正確形式。",
      "instruction_de": "Sind das seine oder ihre Dinge? Markieren Sie auch Nominativ & Akkusativ.",
      "questions": [
        {
          "id": "ch2-ex1a",
          "label": "a)",
          "type": "fill-blank",
          "prompt_md": "Mario benutzt ___ Rucksack jeden Tag.",
          "answer": [
            "seinen"
          ],
          "hint_zh": "der Rucksack 陽性、Akk"
        },
        {
          "id": "ch2-ex1b",
          "label": "b)",
          "type": "fill-blank",
          "prompt_md": "Iris sucht ___ Handy. Mario hat es auch nicht gesehen.",
          "answer": [
            "ihr"
          ],
          "hint_zh": "das Handy 中性、Akk"
        },
        {
          "id": "ch2-ex1c",
          "label": "c)",
          "type": "fill-blank",
          "prompt_md": "Iris hat kein Fahrrad. Das ist ___ Fahrrad.",
          "answer": [
            "sein",
            "Marios"
          ],
          "hint_zh": "das Fahrrad 中性、是 Mario 的"
        },
        {
          "id": "ch2-ex1d",
          "label": "d)",
          "type": "multi-blank",
          "prompt_md": "Iris liest fast nie. Das sind ___ Bücher. Er liebt ___ Bücher.",
          "answer": [
            [
              "seine",
              "Marios"
            ],
            [
              "seine"
            ]
          ],
          "hint_zh": "die Bücher 複數、是 Mario 的"
        },
        {
          "id": "ch2-ex1e",
          "label": "e)",
          "type": "fill-blank",
          "prompt_md": "Mario hat Iris einen Ring geschenkt. Sie mag ___ neuen Ring.",
          "answer": [
            "ihren"
          ],
          "hint_zh": "der Ring 陽性、Sie 戴的（Akk）"
