    {
      "id": "dativ",
      "title_de": "Dativ",
      "title_zh": "與格",
      "summary_zh": "與格用來標示『間接受詞』、『被某動詞 / 介係詞要求』的對象。最常見：給某人某物（dem Mann das Buch geben）、9 個位置介係詞、14 個 Dativ 動詞、人稱代名詞 mir / dir / ihm / ihr…。",
      "blocks": [
        {
          "type": "table",
          "title": "定冠詞 / 不定冠詞 在 Dativ 的形式",
          "headers": ["", "陽 (m.)", "中 (n.)", "陰 (f.)", "複數 (Pl.)"],
          "rows": [
            ["Nominativ 主格", "der / ein", "das / ein", "die / eine", "die / —"],
            ["Akkusativ 受格", "den / einen", "das / ein", "die / eine", "die / —"],
            ["Dativ 與格", "dem / einem", "dem / einem", "der / einer", "den / —"]
          ]
        },
        {
          "type": "table",
          "title": "物主 / 否定冠詞（mein- / kein-）的 Dativ 變化",
          "headers": ["", "陽 + 中", "陰", "複數"],
          "rows": [
            ["mein-", "meinem", "meiner", "meinen"],
            ["dein-", "deinem", "deiner", "deinen"],
            ["sein- / ihr-", "seinem / ihrem", "seiner / ihrer", "seinen / ihren"],
            ["kein-", "keinem", "keiner", "keinen"]
          ]
        },
        {
          "type": "table",
          "title": "人稱代名詞 完整三格",
          "headers": ["Nominativ", "Akkusativ", "Dativ"],
          "rows": [
            ["ich", "mich", "mir"],
            ["du", "dich", "dir"],
            ["er / es", "ihn / es", "ihm"],
            ["sie", "sie", "ihr"],
            ["wir", "uns", "uns"],
            ["ihr", "euch", "euch"],
            ["sie / Sie", "sie / Sie", "ihnen / Ihnen"]
          ]
        },
        {
          "type": "table",
          "title": "9 個位置介係詞（Wo? → 接 Dativ）",
          "headers": ["介係詞", "中文", "範例"],
          "rows": [
            ["auf", "在…上面（接觸）", "auf dem Tisch"],
            ["unter", "在…下面", "unter dem Bett"],
            ["über", "在…上方（不接觸）", "über dem Sofa"],
            ["in", "在…裡面", "in der Küche"],
            ["vor", "在…前面", "vor der Kirche"],
            ["hinter", "在…後面", "hinter dem Haus"],
            ["an", "在…旁／靠著", "an der Wand"],
            ["neben", "在…隔壁", "neben dem Stuhl"],
            ["zwischen", "在…之間", "zwischen den Pflanzen"]
          ]
        },
        {
          "type": "table",
          "title": "14 個 A1 必背 Dativ 動詞",
          "headers": ["動詞", "中文", "例句"],
          "rows": [
            ["antworten", "回答（某人）", "Ich antworte dir später."],
            ["danken", "感謝", "Ich danke dir."],
            ["gefallen", "讓人喜歡", "Das Haus gefällt mir."],
            ["gehören", "屬於", "Das Auto gehört ihm."],
            ["glauben", "相信（某人）", "Ich glaube dir nicht."],
            ["gratulieren", "祝賀", "Wir gratulieren dir!"],
            ["helfen", "幫忙", "Hilf mir bitte!"],
            ["passen", "（衣物）合身", "Die Schuhe passen ihm nicht."],
            ["schmecken", "（食物）合口味", "Die Pizza schmeckt mir."],
            ["stehen", "（外觀）適合", "Der Bart steht ihm gut."],
            ["weh|tun", "讓某人痛", "Mein Bein tut mir weh."],
            ["zu|hören", "聆聽", "Hör mir bitte zu!"],
            ["es geht …", "某人覺得…", "Mir geht es gut."],
            ["folgen", "跟隨", "Folgen Sie mir!"]
          ]
        },
        {
          "type": "tip",
          "text": "重要：複數名詞在 Dativ 時，如果原本不是 -n 結尾要加 -n（die Kinder → den Kindern）。例外：以 -s 結尾不加（die Autos → den Autos）。"
        },
        {
          "type": "tip",
          "text": "縮寫：in + dem = im、an + dem = am、zu + dem = zum、zu + der = zur、von + dem = vom、bei + dem = beim。這些都是 Dativ 的縮寫，超常用。"
        }
      ],
      "see_chapters": [1, 4, 5]
    },

    {
      "id": "satzbau",
      "title_de": "Satzbau — Hauptsatz / Nebensatz",
      "title_zh": "句子結構：主句 / 子句",
      "summary_zh": "德文句子規則：主句的『被變位的動詞』永遠在第二位（問句在第一位）。子句（Nebensatz）由連接詞引導，動詞被踢到最後。",
      "blocks": [
        {
          "type": "table",
          "title": "Hauptsatz（主句）— 動詞放第二位",
          "headers": ["位置 1", "位置 2 (動詞)", "中段", "句尾"],
          "rows": [
            ["Er", "spielt", "morgen", "Fußball."],
            ["Morgen", "spielt", "er", "Fußball."],
            ["Er", "kann", "gut Fußball", "spielen."],
            ["Wir", "haben", "gestern", "gegessen."]
          ]
        },
        {
          "type": "tip",
          "text": "把時間 / 地點放第一位時，主詞要跑到動詞後面（位置 3）。動詞死守第二位。"
        },
        {
          "type": "table",
          "title": "Ja / Nein 問句 — 動詞放第一位",
          "headers": ["位置 1 (動詞)", "位置 2 (主詞)", "其他"],
          "rows": [
            ["Spielst", "du", "Fußball?"],
            ["Hast", "du", "Hunger?"]
          ]
        },
        {
          "type": "table",
          "title": "Hauptsatz 連接詞（不影響動詞位置）",
          "headers": ["連接詞", "中文", "範例"],
          "rows": [
            ["und", "和", "Ich bin müde und ich gehe ins Bett."],
            ["aber", "但是", "Ich mag Pizza, aber ich esse keine."],
            ["oder", "或", "Wir gehen ins Kino oder wir bleiben zu Hause."],
            ["denn", "因為（口語感）", "Ich lerne Deutsch, denn ich möchte in Berlin arbeiten."]
          ]
        },
        {
          "type": "table",
          "title": "Nebensatz（子句）— 動詞放最後",
          "headers": ["主句（結果）", ",", "連接詞", "主詞 + 中段", "動詞放最後"],
          "rows": [
            ["Sie ist nervös", ",", "weil", "sie morgen einen Test", "schreibt."],
            ["Er ist zu Hause", ",", "weil", "er Hausaufgaben machen", "muss."],
            ["Janosh ist reich", ",", "weil", "er im Lotto gewonnen", "hat."]
          ]
        },
        {
          "type": "tip",
          "text": "可分動詞在子句裡會『合體』：er räumt auf → weil er aufräumt（單一動詞放最後）。情態動詞句的子句：本動詞原型 + 變位的情態動詞放最後（…machen muss）。"
        },
        {
          "type": "table",
          "title": "denn vs weil（兩個都是『因為』）",
          "headers": ["特徵", "denn", "weil"],
          "rows": [
            ["後面句子結構", "主句結構（動詞第二位）", "子句結構（動詞放最後）"],
            ["逗點", "前面要逗點", "前面要逗點"],
            ["建議", "口語常用、容易", "正式 / 寫作首選"]
          ]
        }
      ],
      "see_chapters": [4, 9]
    },

    {
      "id": "imperativ",
      "title_de": "Imperativ",
      "title_zh": "命令式（祈使句）",
      "summary_zh": "三種命令式：① 對長輩 / 客戶用 Sie；② 對單一熟人用 du；③ 對複數熟人用 ihr。動詞都放第一位。加 bitte 變客氣、加 doch 變建議。",
      "blocks": [
        {
          "type": "table",
          "title": "三種命令式 — 規則彙整",
          "headers": ["對誰", "規則", "範例：machen → ?"],
          "rows": [
            ["Sie", "Sie 的變位（=動詞原型） + Sie", "Machen Sie ...!"],
            ["du", "du 變位 → 拿掉 -st 與 du", "Mach ...!"],
            ["ihr", "ihr 變位（=動詞變位後一樣） → 拿掉 ihr", "Macht ...!"]
          ]
        },
        {
          "type": "table",
          "title": "重要動詞的命令式",
          "headers": ["原型", "Sie", "du", "ihr"],
          "rows": [
            ["machen", "Machen Sie!", "Mach!", "Macht!"],
            ["nehmen", "Nehmen Sie!", "Nimm!", "Nehmt!"],
            ["lesen", "Lesen Sie!", "Lies!", "Lest!"],
            ["geben", "Geben Sie!", "Gib!", "Gebt!"],
            ["sprechen", "Sprechen Sie!", "Sprich!", "Sprecht!"],
            ["essen", "Essen Sie!", "Iss!", "Esst!"],
            ["schlafen", "Schlafen Sie!", "Schlaf!", "Schlaft!"],
            ["fahren", "Fahren Sie!", "Fahr!", "Fahrt!"],
            ["sein", "Seien Sie!", "Sei!", "Seid!"],
            ["haben", "Haben Sie!", "Hab!", "Habt!"]
          ]
        },
        {
          "type": "tip",
          "text": "強動詞（e → i / ie 換音）的 du 命令式跟著 du 變位走：du sprichst → Sprich! du nimmst → Nimm! 但 a → ä 不適用：du fährst → Fahr!（去 Umlaut）。"
        },
        {
          "type": "tip",
          "text": "加 bitte 變客氣：Mach bitte deine Hausaufgaben!；加 doch 變『不如…吧』的建議：Trinken Sie doch einen Tee.（不如喝杯茶吧。）"
        }
      ],
      "see_chapters": [6, 8]
    },

    {
      "id": "modalverben",
      "title_de": "Modalverben",
      "title_zh": "情態動詞",
      "summary_zh": "A1 常見的情態動詞：können（會 / 能）、wollen（想要）、möchten（想要，禮貌版）、sollen（被交代）、müssen（必須）、dürfen（被允許）。共通規則：情態動詞變位放第二位，主要動詞用原型放句尾。",
      "blocks": [
        {
          "type": "table",
          "title": "6 個情態動詞變位",
          "headers": ["", "können", "wollen", "möchten", "sollen", "müssen", "dürfen"],
          "rows": [
            ["ich", "kann", "will", "möchte", "soll", "muss", "darf"],
            ["du", "kannst", "willst", "möchtest", "sollst", "musst", "darfst"],
            ["er/sie/es", "kann", "will", "möchte", "soll", "muss", "darf"],
            ["wir", "können", "wollen", "möchten", "sollen", "müssen", "dürfen"],
            ["ihr", "könnt", "wollt", "möchtet", "sollt", "müsst", "dürft"],
            ["sie/Sie", "können", "wollen", "möchten", "sollen", "müssen", "dürfen"]
          ]
        },
        {
          "type": "table",
          "title": "意思與用法對比",
          "headers": ["動詞", "中文", "場景"],
          "rows": [
            ["können", "會 / 能", "Ich kann Deutsch sprechen."],
            ["wollen", "想要（直接）", "Ich will reich werden."],
            ["möchten", "想要（禮貌）", "Ich möchte einen Kaffee, bitte."],
            ["sollen", "被交代要…", "Der Arzt hat gesagt, ich soll viel Wasser trinken."],
            ["müssen", "必須", "Ich muss morgen früh aufstehen."],
            ["dürfen", "被允許", "Darf ich rein kommen?"]
          ]
        },
        {
          "type": "tip",
          "text": "陷阱：英文 must not = 德文 darf nicht（被禁止），不是 muss nicht！muss nicht = 不必。例：Du musst nicht kommen.（你不必來）≠ Du darfst nicht kommen.（你不能來）。"
        },
        {
          "type": "tip",
          "text": "wollen 在德國人耳裡很直接，不適合餐廳點餐。請用 möchten。例：『Ich möchte ein Bier, bitte.』比 『Ich will ein Bier』禮貌得多。"
        }
      ],
      "see_chapters": [5, 6, 9]
    },

